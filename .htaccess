# hostinger
RewriteEngine On

# Force login → staff.php
RewriteRule ^login/?$ /staff.php [L]

# Clean URLs for other php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ /$1.php [L]